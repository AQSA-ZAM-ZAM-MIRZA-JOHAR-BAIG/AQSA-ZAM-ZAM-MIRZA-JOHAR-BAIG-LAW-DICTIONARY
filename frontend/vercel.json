{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.+)/",
      "destination": "/$1",
      "permanent": true
    },
    {
      "source": "/terms/(.*)[\\-\\.\\\\]+",
      "destination": "/terms/$1",
      "permanent": true
    },
    {
      "source": "/terms/(.*)%20",
      "destination": "/terms/$1",
      "permanent": true
    },
    {
      "source": "/terms/dictionary(.*)",
      "destination": "/dictionary",
      "permanent": true
    },
    {
      "source": "/terms/bookmarks(.*)",
      "destination": "/bookmarks",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
